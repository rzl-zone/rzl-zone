{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm clean:.next && pnpm run generate:all-docs-cache && pnpm compile:translations && fumadocs-mdx && next build",
    "build:start-docs": "pnpm run build && pnpm run start-docs",
    "dev:docs": "pnpm clean:.next && pnpm compile:translations && fumadocs-mdx && next dev -p 3001",
    "dev:watch-docs": "pnpm run generate:all-docs-cache && concurrently \"pnpm run watch:docs\" \"pnpm run dev:docs\"",
    "start-docs": "next start -p 3001",
    "clean:.next": "del-cli --force .next || true",
    "watch:docs": "tsx scripts/watch-docs.ts",
    "compile:translations": "fuma-translate \"src/**/*.{ts,tsx}\" \"src/*.{ts,tsx}\"",
    "generate:all-docs-cache": "pnpm run generate:docs-cache && pnpm run generate:sitemap-docs && pnpm run generate:json_ld-docs",
    "generate:docs-cache": "tsx scripts/generate-docs-cache.ts",
    "generate:sitemap-docs": "tsx scripts/generate-sitemap.ts",
    "generate:json_ld-docs": "tsx scripts/generate-json_ld-docs.ts",
    "tsc:check": "tsc --noEmit",
    "types:check": "pnpm run generate:all-docs-cache && fumadocs-mdx && next typegen && tsc --noEmit",
    "lint": "eslint"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.195",
    "@base-ui/react": "1.6.0",
    "@fuma-translate/react": "^1.0.2",
    "@mdx-js/mdx": "^3.1.1",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@rzl-zone/core": "workspace:*",
    "@rzl-zone/core-react": "workspace:*",
    "@rzl-zone/docs-ui": "workspace:*",
    "@rzl-zone/next-kit": "workspace:*",
    "@rzl-zone/utils-js": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@takumi-rs/image-response": "^1.8.6",
    "@workspace/fd-shiki": "workspace:*",
    "ai": "^6.0.208",
    "estree-util-value-to-estree": "^3.5.0",
    "flexsearch": "^0.8.212",
    "fuma-translate": "^1.0.2",
    "fumadocs-core": "16.10.4",
    "fumadocs-docgen": "3.0.10",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-twoslash": "3.2.0",
    "fumadocs-typescript": "5.2.6",
    "fumadocs-ui": "16.10.4",
    "github-slugger": "^2.0.0",
    "hast-util-to-estree": "^3.1.3",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "mdast-util-mdx": "^3.0.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-rehype": "^11.1.2",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@rzl-zone/build-tools": "workspace:*",
    "@rzl-zone/eslint": "workspace:*",
    "@rzl-zone/ts-types-plus": "workspace:*",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/estree": "^1.0.9",
    "@types/estree-jsx": "^1.0.5",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.0",
    "gray-matter": "^4.0.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "unified": "^11.0.5"
  }
}
