{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm run generate:all-docs-cache && fumadocs-mdx && next build",
    "build:start-docs": "pnpm run build && pnpm run start-docs",
    "dev:docs": "pnpm clean:.next && fumadocs-mdx && cross-env next dev -p 13003",
    "dev:watch-docs": "pnpm generate:all-docs-cache && concurrently \"pnpm run watch:docs\" \"pnpm run dev:docs\"",
    "start-docs": "next start -p 13003",
    "clean:.next": "del-cli --force .next packages/*/.next apps/*/.next || true",
    "watch:docs": "tsx scripts/watch-docs.ts",
    "generate:all-docs-cache": "pnpm run generate:docs-cache && pnpm run generate:sitemap && pnpm run generate:robots-txt && pnpm run generate:json_ld-docs",
    "generate:docs-cache": "tsx scripts/generate-docs-cache.ts",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "generate:robots-txt": "tsx scripts/generate-robots.txt.ts",
    "generate:json_ld-docs": "tsx scripts/generate-json_ld-docs.ts",
    "tsc:check": "tsc --noEmit",
    "types:check": "pnpm generate:all-docs-cache && fumadocs-mdx && next typegen && tsc --noEmit",
    "lint": "eslint"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.160",
    "@openrouter/ai-sdk-provider": "^2.5.1",
    "@rzl-zone/build-tools": "workspace:*",
    "@rzl-zone/core": "workspace:*",
    "@rzl-zone/core-react": "workspace:*",
    "@rzl-zone/docs-ui": "workspace:*",
    "@rzl-zone/next-kit": "workspace:*",
    "@rzl-zone/ts-types-plus": "workspace:*",
    "@rzl-zone/utils-js": "latest",
    "@smakss/react-scroll-direction": "^4.3.1",
    "@takumi-rs/image-response": "^1.0.7",
    "ai": "^6.0.158",
    "cross-env": "^10.1.0",
    "flexsearch": "^0.8.212",
    "framer-motion": "^12.38.0",
    "fumadocs-core": "^16.7.14",
    "fumadocs-mdx": "14.2.13",
    "fumadocs-typescript": "5.2.4",
    "fumadocs-ui": "16.7.4",
    "github-slugger": "^2.0.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@rzl-zone/eslint": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/estree": "^1.0.8",
    "@types/estree-jsx": "^1.0.5",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/fd-shiki": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.0",
    "estree-util-value-to-estree": "^3.5.0",
    "fumadocs-docgen": "3.0.10",
    "fumadocs-twoslash": "3.1.17",
    "gray-matter": "^4.0.3",
    "hast-util-to-estree": "^3.1.3",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "mdast-util-mdx": "^3.0.0",
    "postcss": "^8.5.9",
    "rehype-katex": "^7.0.1",
    "remark": "^15.0.1",
    "remark-math": "^6.0.0",
    "remark-rehype": "^11.1.2",
    "tailwindcss": "^4.2.2",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3",
    "zod": "^4.3.6"
  }
}
