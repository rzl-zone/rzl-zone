{
  "extends": "@workspace/typescript-config/react-library.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "importHelpers": true,
    "sourceMap": true,
    "rootDir": "src",
    "declarationMap": false,
    "allowSyntheticDefaultImports": true,
    "plugins": [
      {
        "name": "typescript-plugin-css-modules"
      }
    ],
    "target": "es5",
    "lib": [
      "es5",
      "es6",
      "dom",
      "es2016",
      "es2017"
    ],
    "module": "esnext",
    "moduleResolution": "bundler"
  },
  "include": [
    "types",
    "*.config.ts",
    "./src/**/*"
  ],
  "exclude": [
    "dist",
    "_deprecated",
    "node_modules"
  ]
}
