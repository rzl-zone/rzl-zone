{
  "extends": "@workspace/typescript-config/react-library.json",
  "compilerOptions": {
    "outDir": "dist",
    "target": "esnext",
    "module": "esnext",
    "declarationMap": false,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "types",
    "*.config.ts",
    "./src/**/*"
  ],
  "exclude": [
    "_deprecated",
    "node_modules"
  ]
}
