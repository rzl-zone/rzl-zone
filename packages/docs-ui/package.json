{
  "name": "@rzl-zone/docs-ui",
  "version": "0.0.4",
  "description": "A custom UI setup for the Rzl Zone documentation monorepo website.",
  "license": "MIT",
  "author": "Rizalvin Dwiky <rizalvindwiky1998@gmail.com>",
  "contributors": [
    "Rizalvin Dwiky <rizalvindwiky1998@gmail.com>"
  ],
  "homepage": "https://github.com/rzl-zone/rzl-zone/tree/main/packages/docs-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rzl-zone/rzl-zone.git",
    "directory": "packages/docs-ui"
  },
  "keywords": [
    "rzl-zone",
    "rzl-zone-monorepo",
    "docs-ui"
  ],
  "type": "module",
  "sideEffects": [
    "*.css",
    "./dist/styles/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "!**/*.test.*"
  ],
  "exports": {
    "./.references": {
      "import": {
        "types": "./dist/.references/index.d.ts"
      },
      "require": {
        "types": "./dist/.references/index.d.cts"
      }
    },
    "./styles/globals.css": "./dist/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./components/*": {
      "import": {
        "types": "./dist/components/*.d.ts",
        "default": "./dist/components/*.js"
      },
      "require": {
        "types": "./dist/components/*.d.cts",
        "default": "./dist/components/*.cjs"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils/index.d.ts",
        "default": "./dist/utils/index.js"
      },
      "require": {
        "types": "./dist/utils/index.d.cts",
        "default": "./dist/utils/index.cjs"
      }
    }
  },
  "scripts": {
    "check-types:package": "tsc --noEmit",
    "dev:package": "tsdown --watch \"./src/**/*\"",
    "build": "tsdown && pnpm build:tailwind",
    "build:tailwind": "tailwindcss -i src/styles/globals.css -o ./dist/styles/globals.css",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fumadocs/base-ui": "^16.7.14",
    "@headlessui/react": "^2.2.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-direction": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-presence": "^1.1.5",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@rzl-zone/click-feedback": "workspace:*",
    "@rzl-zone/core": "workspace:*",
    "@rzl-zone/core-react": "workspace:*",
    "@rzl-zone/next-kit": "workspace:*",
    "@rzl-zone/utils-js": "latest",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.8.0",
    "scroll-into-view-if-needed": "^3.1.0",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@rzl-zone/build-tools": "workspace:*",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@turbo/gen": "^2.9.6",
    "@types/node": "^20.19.27",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.2",
    "postcss-load-config": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "tsdown": "0.21.8",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    },
    "tailwindcss": {
      "optional": false
    }
  }
}
