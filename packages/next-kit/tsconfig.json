{
  "extends": "@workspace/typescript-config/react-library.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": false,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "types",
    "*.config.ts",
    "./src/**/*",
    "./scripts/**/*",
    "_deprecated/scripts/minifyDtsDist.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "eslint.config.mjs",
    "_deprecated"
  ]
}
